# Copie este arquivo para ".env" nesta mesma pasta (deploy/) antes de subir
# o docker-compose.yml no ZimaOS/CasaOS. Use valores fortes e únicos aqui —
# isso é produção, não dev local.

# Usuário do Docker Hub onde a imagem foi publicada (ver build-and-push.sh)
DOCKERHUB_USER=seu-usuario-dockerhub

# Senha do banco Postgres (gere algo forte, ex: openssl rand -hex 16)
DB_PASSWORD=troque-esta-senha-do-banco

# Segredo usado para assinar os tokens JWT (gere algo forte, ex: openssl rand -hex 32)
JWT_SECRET=troque-este-segredo-bem-longo-e-aleatorio
JWT_EXPIRES_IN=7d
MAX_UPLOAD_SIZE_MB=15

# Usuário administrador criado automaticamente no primeiro start
ADMIN_EMAIL=esposa@example.com
ADMIN_PASSWORD=troque-esta-senha-admin
ADMIN_NAME=Administradora

# E-mail (opcional) — resumo diário de tarefas para os administradores.
# Deixe em branco para desativar.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Marketing Tracker <no-reply@marketing-tracker.local>
DAILY_DIGEST_HOUR=8
