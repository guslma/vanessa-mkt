# Copie este arquivo para ".env" na raiz do projeto e ajuste os valores.
# Usado pelo docker-compose.yml (dev local). Para produção/ZimaOS, use
# deploy/.env.example (variáveis equivalentes, com valores de produção).

# ---- Banco de dados ----
DB_PASSWORD=marketing_dev_pw

# ---- Backend ----
# DATABASE_URL só é usada se você rodar o backend fora do Docker
# (dentro do container, o docker-compose.yml já injeta o valor correto).
DATABASE_URL=postgres://marketing:marketing_dev_pw@localhost:5432/marketing
JWT_SECRET=dev_secret_change_me
JWT_EXPIRES_IN=7d
MAX_UPLOAD_SIZE_MB=15

# ---- Usuário administrador criado automaticamente no primeiro start ----
ADMIN_EMAIL=admin@marketing.local
ADMIN_PASSWORD=admin123456
ADMIN_NAME=Administradora

# ---- E-mail (opcional) — resumo diário de tarefas para os administradores ----
# Deixe em branco para desativar (nenhum e-mail é enviado se SMTP_HOST não estiver definido).
# Exemplo com Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=seu-email@gmail.com,
# SMTP_PASSWORD=senha de app (não a senha normal da conta).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Marketing Tracker <no-reply@marketing-tracker.local>
DAILY_DIGEST_HOUR=8
